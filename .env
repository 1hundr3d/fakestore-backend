# Конфигурация базы данных
# Для локальной разработки используется SQLite
# DATABASE_URL=sqlite:///./fakestore.db
# 
# Для Docker (PostgreSQL) используйте:
# DATABASE_URL=postgresql://admin:secret@db:5432/fakestore

DATABASE_URL=sqlite:///./fakestore.db
TEST_DATABASE_URL=sqlite:///./test.db

# Секретный ключ для JWT токенов
# В production используйте более сложный ключ!
SECRET_KEY=mysecretkey1234567890

# Конфигурация Redis (опционально)
# Если Redis недоступен, кэширование работать не будет
# REDIS_URL=redis://localhost:6379/0