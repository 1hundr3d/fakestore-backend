# ===========================================
# Пример конфигурационного файла .env
# ===========================================
# Скопируйте этот файл в .env и настройте под свои нужды
# cp .env.example .env

# ===========================================
# База данных
# ===========================================
# Для локальной разработки (SQLite):
DATABASE_URL=sqlite:///./fakestore.db
TEST_DATABASE_URL=sqlite:///./test.db

# Для Docker/Production (PostgreSQL):
# DATABASE_URL=postgresql://admin:secret@db:5432/fakestore
# TEST_DATABASE_URL=postgresql://admin:secret@db:5432/fakestore_test

# ===========================================
# Безопасность
# ===========================================
# Секретный ключ для JWT токенов
# В production используйте сложный случайный ключ!
# Сгенерировать можно командой: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=mysecretkey1234567890

# ===========================================
# Redis (кэширование)
# ===========================================
# Для локальной разработки (если Redis установлен):
# REDIS_URL=redis://localhost:6379/0

# Для Docker:
# REDIS_URL=redis://redis:6379/0

# Если REDIS_URL не задан, кэширование работать не будет
# (приложение продолжит работать, но без кэширования)

# ===========================================
# Другие настройки
# ===========================================
# DEBUG=False  # Установите True для включения режима отладки